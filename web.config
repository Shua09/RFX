<configuration>
  <system.webServer>
    <!-- Remove WebDAV -->
    <modules>
        <remove name="WebDAVModule" />
    </modules>
    
    <handlers>
        <remove name="WebDAV" />
        <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
        <remove name="OPTIONSVerbHandler" />
        <remove name="TRACEVerbHandler" />
        
        <add name="StaticFileCSS" path="*.css" verb="*" modules="StaticFileModule" resourceType="File" requireAccess="Read" />
        <add name="Python FastCGI"
             path="*"
             verb="GET,HEAD,POST,PUT,DELETE,OPTIONS,PATCH"
             modules="FastCgiModule"
             scriptProcessor="C:\Users\noahadmin\AppData\Local\Programs\Python\Python311\python.exe|C:\Users\noahadmin\AppData\Local\Programs\Python\Python311\Lib\site-packages\wfastcgi.py"
             resourceType="Unspecified"
             requireAccess="Script" />
    </handlers>
    
    <security>
        <requestFiltering>
            <verbs allowUnlisted="true">
                <add verb="GET" allowed="true" />
                <add verb="POST" allowed="true" />
                <add verb="PUT" allowed="true" />
                <add verb="DELETE" allowed="true" />
                <add verb="OPTIONS" allowed="true" />
                <add verb="PATCH" allowed="true" />
            </verbs>
        </requestFiltering>
    </security>

    <httpProtocol>
      <customHeaders>
        <remove name="Cache-Control"/>
        <remove name="Pragma"/>
        <remove name="Expires"/>
        <add name="Cache-Control" value="no-cache, no-store, must-revalidate"/>
        <add name="Pragma" value="no-cache"/>
        <add name="Expires" value="-1"/>
        <!-- Add CORS headers if needed -->
        <add name="Access-Control-Allow-Origin" value="https://delca.noahapplication.com" />
        <add name="Access-Control-Allow-Methods" value="GET, POST, PUT, DELETE, OPTIONS, PATCH" />
        <add name="Access-Control-Allow-Headers" value="Content-Type, Authorization, Origin, Accept" />
      </customHeaders>
    </httpProtocol>
    
    <caching enabled="false"/>
    
    <!-- FIXED URL rewrite rules -->
    <rewrite>
      <rules>
        <!-- IMPORTANT: Clear existing rules first -->
        <clear />
        
        <!-- Rule 1: Serve static files directly -->
        <rule name="Static Files" stopProcessing="true">
          <match url="^RFX/static/(.*)" />
          <action type="Rewrite" url="/RFX/static/{R:1}" />
        </rule>
        
        <!-- Rule 2: Serve CSS, JS, images, fonts directly -->
        <rule name="Static Assets" stopProcessing="true">
          <match url="^RFX/(.*\.(css|js|png|jpg|gif|ico|woff|woff2|ttf|eot|svg|map))$" />
          <action type="Rewrite" url="/RFX/{R:1}" />
        </rule>
        
        <!-- Rule 3: API requests - Forward to Flask -->
        <rule name="API Requests" stopProcessing="true">
          <match url="^RFX/api/(.*)" />
          <action type="Rewrite" url="/RFX/{R:0}" />
        </rule>
        
        <!-- Rule 4: Default route for SPA -->
        <rule name="SPA Default" stopProcessing="true">
          <match url="^RFX/?$" />
          <action type="Rewrite" url="/RFX/" />
        </rule>
        
        <!-- Rule 5: Catch-all for SPA client-side routing -->
        <rule name="SPA Routing" stopProcessing="true">
          <match url="^RFX/.*" />
          <conditions logicalGrouping="MatchAll" trackAllCaptures="false">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/RFX/" />
        </rule>
      </rules>
    </rewrite>
    
    <!-- Add this to handle OPTIONS requests for CORS -->
    <httpErrors errorMode="Detailed" />
    
  </system.webServer>

  <appSettings>
    <add key="WSGI_HANDLER" value="wsgi.application" />
    <add key="PYTHONPATH" value="C:\inetpub\wwwroot\RFX" />
    <add key="WSGI_LOG" value="C:\inetpub\wwwroot\RFX\logs\iis.log" />
    <add key="BASE_ROUTE" value="/RFX" />
    <!-- Add these for better debugging -->
    <add key="WSGI_RESTART_FILE_REGEX" value="" />
    <add key="WSGI_ALT_VIRTUALENV_HANDLER" value="" />
    <add key="WSGI_ALT_VIRTUALENV_ACTIVATE_THIS" value="" />
  </appSettings>
</configuration>